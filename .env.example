# ─────────────────────────────────────────────────
#  BlogSpace – Environment Variables
# ─────────────────────────────────────────────────
#
#  AI Features use Google Gemini (FREE)
#
#  Steps:
#   1. Go to: https://aistudio.google.com/app/apikey
#   2. Click "Create API Key" (free, no card needed)
#   3. Copy the key and paste below
#   4. Rename this file to .env
#   5. Run: npm install && npm run dev
#
# ─────────────────────────────────────────────────

VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────────────
#  Without this key, AI panel runs in demo mode
#  (mock responses). Everything else works fine.
# ─────────────────────────────────────────────────
